import React from 'react';
import { useQuery } from '@tanstack/react-query';
import { api } from '../../api/client';
import { PageHeader } from '../../components/PageHeader';

interface AnalyticsSummary {
  rides_today: number;
  revenue_today_cents: number;
  active_drivers: number;
  active_rides: number;
  currency: string;
}

export function DashboardPage(): JSX.Element {
  const { data, isLoading } = useQuery({
    queryKey: ['analytics', 'summary'],
    queryFn: () => api<AnalyticsSummary>('/v1/admin/analytics/summary'),
    refetchInterval: 30_000,
  });

  return (
    <>
      <PageHeader title="Dashboard" subtitle="Live operations overview." />
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
        <Stat label="Rides today" value={data?.rides_today ?? (isLoading ? '…' : 0)} />
        <Stat
          label="Revenue today"
          value={data ? `$${(data.revenue_today_cents / 100).toFixed(2)}` : isLoading ? '…' : '$0.00'}
        />
        <Stat label="Active drivers" value={data?.active_drivers ?? (isLoading ? '…' : 0)} />
        <Stat label="Active rides" value={data?.active_rides ?? (isLoading ? '…' : 0)} />
      </div>
      <div className="mt-8 p-6 border border-border rounded bg-surface text-sm text-muted">
        TODO: live map of online drivers and active rides (FR-ADMIN-003).
      </div>
    </>
  );
}
function Stat({ label, value }: { label: string; value: React.ReactNode }) {
  return (
    <div className="border border-border rounded p-4 bg-bg">
      <div className="text-xs text-muted">{label}</div>
      <div className="text-2xl font-semibold mt-1">{value}</div>
    </div>
  );
}
